# =============================================
# ERE SOLAR BOT — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# NE JAMAIS committer .env.local
# Encodage : UTF-8 sans BOM (Out-File PowerShell encode en UTF-16, attention)
# =============================================

# --- Supabase (eu-west-2 London) ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================
# STACK GRATUITE (post-refacto Mehdi avril 2026)
# =============================================

# --- API Adresse data.gouv.fr (géocodage) ---
# Aucune clé requise — pas de var nécessaire

# --- PVGIS (Commission européenne, calcul solaire) ---
# Aucune clé requise — pas de var nécessaire
# PVGIS_BASE_URL=https://re.jrc.ec.europa.eu/api/v5_2  # surcharge optionnelle

# --- IGN orthophoto WMS (image aérienne microsite) ---
# Aucune clé requise — pas de var nécessaire

# --- BDNB CSTB (sourcing bâtiments) ---
# Aucune clé requise — API publique

# --- API SIRENE / Annuaire des Entreprises (entreprise + dirigeants) ---
# Inscription : https://api.insee.fr/catalogue/site/themes/wso2/subthemes/insee/pages/item-info.jag?name=Sirene&version=V3.11
# OAuth2 client_credentials, token valide 7 jours
INSEE_CONSUMER_KEY=
INSEE_CONSUMER_SECRET=

# --- Hunter.io (recherche email pro depuis domaine) ---
# Inscription : https://hunter.io/users/sign_up
# Plan gratuit : 25 domain-search/mois + 50 email-verifier/mois
# Reset le 1er du mois — bien planifier les batchs d'enrichissement
HUNTER_API_KEY=

# --- Brevo (envoi emails outreach) ---
# Inscription : https://www.brevo.com/
# Plan gratuit : 300 emails/jour
# Webhooks à configurer : delivered, opened, click, hard_bounce, spam
BREVO_API_KEY=
BREVO_SENDER_EMAIL=contact@ere-experts.fr
BREVO_SENDER_NAME=ERE Experts

# --- Cadastre data.gouv.fr (parcelles bonus) ---
# CADASTRE_API_URL=https://cadastre.data.gouv.fr/bundler/cadastre-etalab  # surcharge optionnelle

# =============================================
# SERVICES OPTIONNELS / FUTURS
# =============================================

# --- Claude API (génération email outreach personnalisé — SOL-25) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Cal.com (prise de RDV CTA microsite) ---
CALCOM_API_KEY=

# =============================================
# SERVICES OBSOLÈTES (laissés pour rétro-compat — à supprimer après J9)
# =============================================
# GOOGLE_MAPS_API_KEY=        # remplacé par IGN orthophoto
# GOOGLE_SOLAR_API_KEY=       # remplacé par PVGIS
# PAPPERS_API_KEY=            # remplacé par SIRENE INSEE
# DROPCONTACT_API_KEY=        # remplacé par Hunter.io
# LEMLIST_API_KEY=            # remplacé par Brevo
